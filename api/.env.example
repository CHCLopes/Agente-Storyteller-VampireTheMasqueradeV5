# ==============================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE - BACKEND (FastAPI)
# ==============================================================================
# Renomeie este arquivo para '.env' no diretório 'api/' para desenvolvimento local.
# Em produção (Railway), defina essas chaves na interface web do painel.
# ==============================================================================

# ------------------------------------------------------------------------------
# A. Servidor Backend FastAPI & Uvicorn
# ------------------------------------------------------------------------------
# Define o modo de execução: "development" (local) ou "production" (Railway)
# MUDANÇA: "production" ativa tratamento rígido de erros e otimizações de performance.
ENVIRONMENT=development

# Interface de rede de escuta. "127.0.0.1" localmente; "0.0.0.0" no container Railway.
HOST=127.0.0.1

# Porta de escuta do servidor ASGI Uvicorn (padrão FastAPI)
PORT=8000

# Nível mínimo de logs printados: "INFO", "DEBUG", "WARNING" ou "ERROR"
# MUDANÇA: Em produção, mude para "WARNING" para evitar sobrecarga de logs em disco.
LOG_LEVEL=INFO

# Modo de depuração automática do FastAPI (ativa autoreload local)
# MUDANÇA: Deve ser "false" em produção por razões de performance e segurança.
DEBUG=true

# ------------------------------------------------------------------------------
# B. Persistência de Dados e Banco de Dados (SQLite/PostgreSQL)
# ------------------------------------------------------------------------------
# String de conexão com banco de dados de persistência de metadados da campanha.
# Rationale: SQLite local para facilidade de desenvolvimento; PostgreSQL em produção.
DATABASE_URL=sqlite:///./campaign.db

# Tamanho máximo de conexões simultâneas mantidas no pool do SQLAlchemy.
# MUDANÇA: Em produção (Railway) com múltiplos acessos de usuários, use 10.
DATABASE_POOL_SIZE=5

# ------------------------------------------------------------------------------
# C. Google Gemini API (Inferência de Linguagem)
# ------------------------------------------------------------------------------
# [SECRET] Chave de API secreta para acesso ao Gemini API, gerada no Google AI Studio.
# ATENÇÃO: Nunca comite o valor real desta chave para o controle de versão!
GEMINI_API_KEY=<YOUR_API_KEY_HERE>

# Identificador do modelo de linguagem gratuito a ser utilizado.
# Rationale: "gemini-2.5-flash" ou "gemini-1.5-flash" recomendados pelo tier gratuito.
GEMINI_MODEL=gemini-2.5-flash

# Rota base do endpoint compatível com OpenAI da Google Gemini API.
# Rationale: Permite usar chamadas httpx/openai padrão mapeando para o Gemini Free.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Tempo limite em segundos para o retorno das chamadas do LLM.
# Rationale: Evita que requisições bloqueadas deixem o backend FastAPI pendente.
GEMINI_TIMEOUT=30

# ------------------------------------------------------------------------------
# D. CORS & Segurança
# ------------------------------------------------------------------------------
# URL do frontend React permitida a fazer requisições cross-origin para o backend.
# MUDANÇA: Ajuste para o endereço gerado pelo Netlify (ex: https://agente-storyteller.netlify.app).
FRONTEND_URL=http://localhost:3000

# Hosts permitidos nos cabeçalhos HTTP de requisições recebidas (proteção contra Host Header Injection).
# MUDANÇA: Em produção deve conter o domínio de API do Railway e o frontend do Netlify.
ALLOWED_HOSTS=localhost,127.0.0.1

# [SECRET] Segredo criptográfico de assinatura para gerenciamento de JWT ou sessões cookies.
# Rationale: Deve ser uma string aleatória longa gerada com segredo seguro.
JWT_SECRET=super_secret_session_token_key_change_me_in_production

# ------------------------------------------------------------------------------
# E. Rate Limiting e Gestão de Cotas (Gemini Free Tier)
# ------------------------------------------------------------------------------
# Limite máximo de requisições permitidas por minuto (RPM) sob a cota do Gemini Free.
GEMINI_MAX_RPM=60

# Limite máximo de tokens processados por mês na cota gratuita do Gemini API.
GEMINI_MAX_MONTHLY_TOKENS=1000000

# Tamanho máximo do buffer/fila interna de requisições de narrativas simultâneas.
# Rationale: Se a fila estiver cheia, novas ações recebem resposta de cooldown imediata.
QUEUE_MAX_SIZE=10

# ------------------------------------------------------------------------------
# F. Logging & Observabilidade
# ------------------------------------------------------------------------------
# Formato estruturado de logs. "text" (humanizado em dev) vs "json" (estruturado em prod)
LOG_FORMAT=text

# URL do Sentry para monitoramento de exceções e erros em produção (opcional).
SENTRY_DSN=
