# === LM Studio Configuration ===
# IMPORTANTE: Substitua "nome-do-modelo" pelo identificador exato do modelo
# carregado no LM Studio (ex: qwen2.5-1.5b-instruct, deepseek-r1-distill-qwen-7b).
# Para verificar, abra LM Studio > Local Server > copie o nome do modelo ativo.
LMSTUDIO_HOST=localhost
LMSTUDIO_PORT=1234
LMSTUDIO_MODEL=nome-do-modelo
LMSTUDIO_TIMEOUT=60
