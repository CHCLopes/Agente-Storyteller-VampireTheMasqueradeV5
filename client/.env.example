# ==============================================================================
# CONFIGURAÇÃO DE VARIÁVEIS DE AMBIENTE - FRONTEND (React 19 / Vite)
# ==============================================================================
# Copie este arquivo como '.env' no diretório 'client/' para desenvolvimento local.
# Em produção (Netlify), defina estas chaves no painel do Netlify Build & Deploy.
#
# OBSERVAÇÃO: Como o projeto utiliza o Vite como empacotador, as variáveis de
# ambiente acessíveis no código React devem possuir o prefixo 'VITE_'.
# Para compatibilidade com scripts legados do CRA, fornecemos ambas as variantes.
# ==============================================================================

# ------------------------------------------------------------------------------
# A. Endpoints do Servidor Backend (API & WebSocket)
# ------------------------------------------------------------------------------
# URL base da API HTTP do backend.
# MUDANÇA: Em produção, mude para "https://agente-storyteller.netlify.app/api" para
# usar a rota de rewrite proxy configurada no netlify.toml, evitando erros de CORS.
VITE_API_URL=http://localhost:8000
REACT_APP_API_URL=http://localhost:8000

# Tempo limite em milissegundos para requisições HTTP AJAX feitas pelo frontend.
VITE_API_TIMEOUT=30000
REACT_APP_API_TIMEOUT=30000

# URL do endpoint de comunicação de tempo real WebSocket.
# Rationale: Netlify não suporta proxying de WebSockets. O frontend deve conectar
# DIRETAMENTE na URL pública do backend no Railway (wss:// no Railway).
# MUDANÇA: Em produção, mude para "wss://agente-storyteller-api.railway.app/ws".
VITE_WS_URL=ws://localhost:8000/ws
REACT_APP_WS_URL=ws://localhost:8000/ws

# ------------------------------------------------------------------------------
# B. Ambiente de Execução
# ------------------------------------------------------------------------------
# Modo de ambiente: "development" (local) ou "production" (Netlify)
VITE_ENV=development
REACT_APP_ENV=development

# Habilita mensagens detalhadas de debug no console do navegador.
# MUDANÇA: Mude para "false" em produção para não poluir o console do jogador.
VITE_DEBUG=true
REACT_APP_DEBUG=true

# ------------------------------------------------------------------------------
# C. Web Analytics (Monitoramento Opcional)
# ------------------------------------------------------------------------------
# Identificador de Rastreamento (ex: ID do Google Analytics). Deixe vazio se desativado.
VITE_ANALYTICS_ID=
REACT_APP_ANALYTICS_ID=
